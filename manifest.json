{
  "manifest_version": 3,
  "name": "MeetMark",
  "version": "1.3.0",
  "description": "Export Microsoft Teams meeting transcripts (including SharePoint Stream recordings) to clean Markdown files, optimized for AI tools. All processing runs locally.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.sharepoint.com/*"
  ],
  "action": {
    "default_title": "MeetMark - Export transcript or capture full page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "minimum_chrome_version": "102",
  "browser_specific_settings": {
    "gecko": {
      "id": "meetmark@extension",
      "strict_min_version": "121.0"
    }
  }
}
